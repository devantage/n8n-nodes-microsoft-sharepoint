{
  "clearMocks": true,
  "collectCoverageFrom": ["src/**/*.ts", "!src/**/*.test.ts", "!src/index.ts"],
  "moduleFileExtensions": ["ts", "js"],
  "roots": ["<rootDir>/src"],
  "testEnvironment": "node",
  "testMatch": ["**/*.test.ts"],
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "tsconfig": {
          "esModuleInterop": true,
          "module": "commonjs",
          "strict": true,
          "types": ["jest", "node"]
        }
      }
    ]
  }
}
